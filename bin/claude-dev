#!/bin/zsh
# Claude Code dev session — attach or create
# Usage: claude-dev [project-path]

PROJECT_DIR="${1:-$(pwd)}"
SESSION_NAME="claude-$(basename "$PROJECT_DIR")"

# attach-session fails when already inside tmux ("sessions should be nested…")
_go() {
  if [[ -n "$TMUX" ]]; then
    tmux switch-client -t "$SESSION_NAME"
  else
    tmux attach -t "$SESSION_NAME"
  fi
}

if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  _go
else
  cd "$PROJECT_DIR" || exit 1
  tmux new-session -d -s "$SESSION_NAME" -n "claude" -x "$(tput cols)" -y "$(tput lines)"
  tmux send-keys -t "$SESSION_NAME:1" "claude" Enter
  tmux split-window -t "$SESSION_NAME:1" -h -p 35 -c "$PROJECT_DIR"
  tmux select-pane -t "$SESSION_NAME:1.1"
  tmux new-window -t "$SESSION_NAME" -n "shell" -c "$PROJECT_DIR"
  tmux select-window -t "$SESSION_NAME:1"
  _go
fi
