#!/bin/bash
# List all tmux sessions for status-left, highlighting the current one
# "agents" session gets cyan coloring
current="$1"
result=""
while IFS= read -r session; do
  if [ "$session" = "$current" ]; then
    result+="#[fg=#F5F3FF,bg=#7C3AED,bold] ${session} #[fg=#A78BFA,bg=#1A1028,nobold] "
  elif [ "$session" = "agents" ]; then
    result+="#[fg=#FB923C,bg=#1A1028] ${session} "
  else
    result+="#[fg=#5B4D7A,bg=#1A1028] ${session} "
  fi
done < <(tmux list-sessions -F '#S' 2>/dev/null)
printf '%s' "$result"
