#!/bin/zsh
# Abbreviate path for tmux status bar
p="${1/#$HOME/~}"

# For worktree paths, just show "wt:<name>"
if [[ "$p" == */.worktrees/* ]]; then
  wtname="${p##*/}"
  (( ${#wtname} > 18 )) && wtname="${wtname:0:15}…"
  echo "wt:${wtname}"
  return
fi

parts=(${(s:/:)p})
if (( ${#parts} <= 3 )); then
  result="$p"
else
  # Only use ~/… when the path is actually under HOME (p starts with ~)
  if [[ "$p" == "~"* ]]; then
    result="~/…/${parts[-2]}/${parts[-1]}"
  else
    result="…/${parts[-2]}/${parts[-1]}"
  fi
fi
# Hard cap at 30 chars
(( ${#result} > 30 )) && result="${result:0:27}…"
echo "$result"
