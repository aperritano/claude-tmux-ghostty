#!/bin/zsh
# Abbreviate path for tmux status bar
p="${1/#$HOME/~}"

# For worktree paths, just show "wt:<name>"
if [[ "$p" == */.worktrees/* ]]; then
  # Strip everything up to and including /.worktrees/, then take the first path
  # component.  ${p##*/} is wrong here: it returns the deepest component (e.g.
  # "lib" for ~/repo/.worktrees/branch/src/lib) instead of the branch name.
  after_wt="${p#*/.worktrees/}"
  wtname="${after_wt%%/*}"
  (( ${#wtname} > 18 )) && wtname="${wtname:0:15}…"
  echo "wt:${wtname}"
  return
fi

parts=(${(s:/:)p})
if (( ${#parts} <= 3 )); then
  result="$p"
else
  result="~/…/${parts[-2]}/${parts[-1]}"
fi
# Hard cap at 30 chars
(( ${#result} > 30 )) && result="${result:0:27}…"
echo "$result"
