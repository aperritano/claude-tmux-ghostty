#!/bin/zsh
# Abbreviate path for tmux status bar
p="${1/#$HOME/~}"

# For worktree paths, just show "wt:<name>"
if [[ "$p" == */.worktrees/* ]]; then
  # Extract the worktree name: the component immediately after .worktrees/
  # ${p##*/} would give the deepest component (wrong when inside a subdir)
  after_wt="${p#*/.worktrees/}"
  wtname="${after_wt%%/*}"
  (( ${#wtname} > 18 )) && wtname="${wtname:0:15}…"
  echo "wt:${wtname}"
  return
fi

parts=(${(s:/:)p})
if (( ${#parts} <= 3 )); then
  result="$p"
else
  result="~/…/${parts[-2]}/${parts[-1]}"
fi
# Hard cap at 30 chars
(( ${#result} > 30 )) && result="${result:0:27}…"
echo "$result"
