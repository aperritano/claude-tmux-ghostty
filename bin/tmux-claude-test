#!/usr/bin/env bash
# tmux-claude-test — regression suite for the Claude/tmux helper script stack.
#
# Runs each script through a minimal sanity test, isolating side effects to
# /tmp where possible. Use after any change to ~/bin/* to confirm nothing
# broke. Pairs with `cc-audit` (which checks "is it wired?") — this answers
# "does it actually run?".
#
# Exit code: 0 if all PASS, 1 if any FAIL.

set -uo pipefail

G="\033[32m"
R="\033[31m"
C="\033[36m"
DIM="\033[90m"
N="\033[0m"

PASS=0
FAIL=0

test_pass() {
  PASS=$((PASS + 1))
  printf "  ${G}✓${N} %s\n" "$1"
}
test_fail() {
  FAIL=$((FAIL + 1))
  printf "  ${R}✗${N} %s — ${R}%s${N}\n" "$1" "$2"
}
section() {
  printf "\n${C}── %s ──${N}\n" "$1"
}

# ─── claude-sessions-list ─────────────────────────────
section "claude-sessions-list"
if [[ -x "$HOME/bin/claude-sessions-list" ]]; then
  out=$("$HOME/bin/claude-sessions-list" 2>/dev/null | head -1)
  if [[ -n "$out" ]]; then
    fields=$(echo "$out" | awk -F'\t' '{print NF}')
    if [[ "$fields" == "5" ]]; then
      test_pass "TSV has 5 fields (age, label, session_id, preview, cwd)"
    else
      test_fail "TSV field count" "got $fields, expected 5"
    fi
  else
    test_fail "produces output" "empty stdout"
  fi
else
  test_fail "executable present" "$HOME/bin/claude-sessions-list missing"
fi

# ─── claude-search ────────────────────────────────────
section "claude-search"
if [[ -x "$HOME/bin/claude-search" ]]; then
  out=$("$HOME/bin/claude-search" ghostty 2>/dev/null | head -1)
  if [[ -n "$out" ]]; then
    test_pass "finds matches for 'ghostty'"
  else
    test_fail "search returns matches" "expected at least one hit (this conversation has 'ghostty')"
  fi
  # Negative case
  out=$("$HOME/bin/claude-search" 'should-never-match-xyzzy123' 2>&1 1>/dev/null)
  if [[ "$out" == *"No matches"* ]]; then
    test_pass "negative case prints 'No matches'"
  else
    test_fail "negative case messaging" "missing"
  fi
else
  test_fail "executable present" "$HOME/bin/claude-search missing"
fi

# ─── claude-worktrees ─────────────────────────────────
section "claude-worktrees"
if [[ -x "$HOME/bin/claude-worktrees" ]]; then
  out=$(cd "$HOME/dev/dotfiles" && "$HOME/bin/claude-worktrees" 2>&1)
  if echo "$out" | grep -q "worktrees in"; then
    test_pass "renders header against real repo"
  else
    test_fail "header" "missing 'worktrees in' line"
  fi
else
  test_fail "executable present" "$HOME/bin/claude-worktrees missing"
fi

# ─── claude-prune-worktrees ───────────────────────────
section "claude-prune-worktrees"
if [[ -x "$HOME/bin/claude-prune-worktrees" ]]; then
  TEST="/tmp/test-prune-$$"
  rm -rf "$TEST"
  mkdir -p "$TEST"
  (
    cd "$TEST"
    git init -q -b main && git commit --allow-empty -q -m initial
    git worktree add -q -b feat-clean .worktrees/clean
  )
  out=$(cd "$TEST" && "$HOME/bin/claude-prune-worktrees" 2>&1)
  rm -rf "$TEST"
  if echo "$out" | grep -q "DRY RUN"; then
    test_pass "dry-run mode (default)"
  else
    test_fail "DRY RUN marker" "not in output"
  fi
  if echo "$out" | grep -qE "(MERGED|ACTIVE)"; then
    test_pass "classifies worktrees"
  else
    test_fail "classification" "no MERGED/ACTIVE lines"
  fi
else
  test_fail "executable present" "$HOME/bin/claude-prune-worktrees missing"
fi

# ─── claude-tail ──────────────────────────────────────
section "claude-tail"
if [[ -x "$HOME/bin/claude-tail" ]]; then
  # Test that --no-args usage message fires for unknown session
  out=$("$HOME/bin/claude-tail" definitely-no-such-session-xyzzy 2>&1)
  if echo "$out" | grep -q "not found"; then
    test_pass "errors cleanly on unknown session"
  else
    test_fail "unknown session" "didn't say 'not found'"
  fi
else
  test_fail "executable present" "$HOME/bin/claude-tail missing"
fi

# ─── claude-today ─────────────────────────────────────
section "claude-today"
if [[ -x "$HOME/bin/claude-today" ]]; then
  out=$("$HOME/bin/claude-today" 2>&1)
  if echo "$out" | grep -qE "Claude Code work|No Claude sessions"; then
    test_pass "renders today summary header"
  else
    test_fail "today header" "neither work-summary nor 'no sessions' line"
  fi
else
  test_fail "executable present" "$HOME/bin/claude-today missing"
fi

# ─── tmux-claude-audit ────────────────────────────────
section "tmux-claude-audit"
if [[ -x "$HOME/bin/tmux-claude-audit" ]]; then
  # Strip ANSI codes so the regex matches the textual content.
  out=$("$HOME/bin/tmux-claude-audit" --quiet 2>&1 | sed $'s/\033\\[[0-9;]*m//g')
  if echo "$out" | grep -qE "PASS[[:space:]]+[0-9]+"; then
    test_pass "outputs PASS count summary"
  else
    test_fail "summary line" "PASS count missing"
  fi
else
  test_fail "executable present" "$HOME/bin/tmux-claude-audit missing"
fi

# ─── tmux-claude-state ────────────────────────────────
section "tmux-claude-state"
if [[ -x "$HOME/bin/tmux-claude-state" ]]; then
  if tmux info >/dev/null 2>&1; then
    out=$("$HOME/bin/tmux-claude-state" 2>&1)
    # Empty output is fine if no claude panes; just ensure it didn't error
    if [[ $? -eq 0 ]]; then
      test_pass "runs against live tmux server (exit 0)"
    else
      test_fail "exit code" "non-zero"
    fi
  else
    test_pass "skipped (no tmux server attached)"
  fi
else
  test_fail "executable present" "$HOME/bin/tmux-claude-state missing"
fi

# ─── tmux-claude-prune ────────────────────────────────
section "tmux-claude-prune"
if [[ -x "$HOME/bin/tmux-claude-prune" ]]; then
  out=$("$HOME/bin/tmux-claude-prune" 90 2>&1)
  # Either reports "No sessions older than..." or "DRY RUN — would archive"
  if echo "$out" | grep -qE "No sessions older|DRY RUN"; then
    test_pass "dry-run mode works"
  else
    test_fail "dry-run output" "neither expected message"
  fi
else
  test_fail "executable present" "$HOME/bin/tmux-claude-prune missing"
fi

# ─── tmux-claude-resurrect-restore ────────────────────
section "tmux-claude-resurrect-restore"
if [[ -x "$HOME/bin/tmux-claude-resurrect-restore" ]]; then
  # Just check syntax (running it would actually inject keystrokes)
  if bash -n "$HOME/bin/tmux-claude-resurrect-restore"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
else
  test_fail "executable present" "$HOME/bin/tmux-claude-resurrect-restore missing"
fi

# ─── tmux-cell-daemon (background process) ───────────
section "tmux-cell-daemon"
if [[ -x "$HOME/bin/tmux-cell-daemon" ]]; then
  if bash -n "$HOME/bin/tmux-cell-daemon"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # Daemon writes a per-UID cache; if stale (>30s) the daemon may be dead.
  cache="/tmp/tmux-window-cell-$UID.cache"
  if [[ -f "$cache" ]]; then
    cache_age=$(( $(date +%s) - $(stat -f %m "$cache" 2>/dev/null || echo 0) ))
    if (( cache_age < 30 )); then
      test_pass "window-cell cache is fresh (${cache_age}s old)"
    else
      test_fail "cache freshness" "${cache_age}s old — daemon may not be running"
    fi
  else
    test_pass "window-cell cache absent (no tmux server or first run)"
  fi
else
  test_fail "executable present" "$HOME/bin/tmux-cell-daemon missing"
fi

# ─── tmux-window-cell (reader) ────────────────────────
section "tmux-window-cell (reader)"
if [[ -x "$HOME/bin/tmux-window-cell" ]]; then
  if bash -n "$HOME/bin/tmux-window-cell"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # Verify it tries to start the daemon when cache is absent.
  if grep -q 'tmux-cell-daemon' "$HOME/bin/tmux-window-cell"; then
    test_pass "falls back to spawning daemon when stale"
  else
    test_fail "daemon fallback" "no reference to tmux-cell-daemon"
  fi
else
  test_fail "executable present" "$HOME/bin/tmux-window-cell missing"
fi

# ─── cc-sound (mute helper) ───────────────────────────
section "cc-sound (mute helper)"
if [[ -x "$HOME/bin/cc-sound" ]]; then
  # Save original mute state
  was_muted=0
  [[ -f "$HOME/.claude/.muted" ]] && was_muted=1

  # Test 1: muted → exit 0, no audio (we trust afplay isn't called)
  touch "$HOME/.claude/.muted"
  if "$HOME/bin/cc-sound" /System/Library/Sounds/Pop.aiff >/dev/null 2>&1; then
    test_pass "respects mute flag (exit 0 with .muted)"
  else
    test_fail "muted exit code" "expected 0"
  fi

  # Test 2: unmuted → still exits 0
  rm -f "$HOME/.claude/.muted"
  if "$HOME/bin/cc-sound" /System/Library/Sounds/Pop.aiff >/dev/null 2>&1; then
    test_pass "plays when unmuted (exit 0)"
  else
    test_fail "unmuted exit code" "expected 0"
  fi

  # Restore original mute state
  if [[ $was_muted -eq 1 ]]; then
    touch "$HOME/.claude/.muted"
  fi
else
  test_fail "cc-sound present" "missing"
fi

# ─── claude-tmux ──────────────────────────────────────
section "claude-tmux"
if [[ -x "$HOME/bin/claude-tmux" ]]; then
  if bash -n "$HOME/bin/claude-tmux"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # Verify it depends on the lister
  if grep -q "claude-sessions-list" "$HOME/bin/claude-tmux"; then
    test_pass "delegates to claude-sessions-list"
  else
    test_fail "lister integration" "no reference to claude-sessions-list"
  fi
else
  test_fail "executable present" "$HOME/bin/claude-tmux missing"
fi

# ─── cc-attention ─────────────────────────────────────
section "cc-attention"
if [[ -x "$HOME/bin/cc-attention" ]]; then
  if bash -n "$HOME/bin/cc-attention"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi

  TMUX_PANE='%99' "$HOME/bin/cc-attention" set 2>/dev/null
  if [[ -e /tmp/cc-attention/99 ]]; then
    test_pass "set creates marker"
  else
    test_fail "set creates marker" "file /tmp/cc-attention/99 missing"
  fi
  TMUX_PANE='%99' "$HOME/bin/cc-attention" clear 2>/dev/null
  if [[ ! -e /tmp/cc-attention/99 ]]; then
    test_pass "clear removes marker"
  else
    rm -f /tmp/cc-attention/99
    test_fail "clear removes marker" "file still present"
  fi
  # Dead-pane gc: marker for a non-existent pane must be reaped on "windows"
  : > /tmp/cc-attention/9999
  "$HOME/bin/cc-attention" windows >/dev/null 2>&1
  if [[ ! -e /tmp/cc-attention/9999 ]]; then
    test_pass "dead-pane gc on 'windows' call"
  else
    test_fail "dead-pane gc" "marker /tmp/cc-attention/9999 still present"
    rm -f /tmp/cc-attention/9999
  fi
else
  test_fail "executable present" "$HOME/bin/cc-attention missing"
fi

# ─── tmux-cell-daemon (pane-headers cache) ────────────
section "tmux-cell-daemon (pane-headers cache)"
if [[ -x "$HOME/bin/tmux-cell-daemon" ]]; then
  cache="/tmp/tmux-pane-headers-$UID.cache"
  if [[ -f "$cache" ]]; then
    age=$(( $(date +%s) - $(stat -f %m "$cache" 2>/dev/null || echo 0) ))
    if (( age < 30 )); then
      test_pass "pane-headers cache fresh (${age}s)"
    else
      test_fail "pane-headers cache freshness" "${age}s old — daemon may not be running"
    fi
  else
    test_pass "pane-headers cache absent (no tmux server or first run)"
  fi
else
  test_fail "executable present" "$HOME/bin/tmux-cell-daemon missing"
fi

# ─── tmux-pane-header (cache-read perf) ───────────────
section "tmux-pane-header (cache-read perf)"
if [[ -x "$HOME/bin/tmux-pane-header" ]]; then
  if bash -n "$HOME/bin/tmux-pane-header"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # Verify daemon cache path is referenced
  if grep -q 'tmux-pane-headers' "$HOME/bin/tmux-pane-header"; then
    test_pass "reads daemon cache (tmux-pane-headers)"
  else
    test_fail "daemon cache reference" "missing"
  fi
  # Verify --compute bypass is implemented (used by daemon itself)
  if grep -q -- '--compute' "$HOME/bin/tmux-pane-header"; then
    test_pass "--compute bypass mode present"
  else
    test_fail "--compute mode" "missing"
  fi
else
  test_fail "executable present" "$HOME/bin/tmux-pane-header missing"
fi

# ─── tmux-burn-segment ────────────────────────────────
section "tmux-burn-segment"
if [[ -x "$HOME/bin/tmux-burn-segment" ]]; then
  if bash -n "$HOME/bin/tmux-burn-segment"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # Nonexistent fixture dir → empty output (no warning, just quiet)
  out=$(CC_BURN_FIXTURE=/nonexistent-path "$HOME/bin/tmux-burn-segment" 2>/dev/null)
  if [[ -z "$out" ]]; then
    test_pass "empty output when projects dir absent"
  else
    test_fail "absent-dir output" "expected empty, got: $out"
  fi
  # At-risk fixture: two records 90s apart, large delta → should trigger warning.
  # cc-burn-rate uses 'tail -n +2' to skip potentially partial first line on
  # real transcripts; add a leading throw-away line so the fixture is realistic.
  fix=$(mktemp -d)
  proj="$fix/proj"
  mkdir -p "$proj"
  now=$(date +%s)
  early=$((now - 120))
  early_ts=$(date -r "$early" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null \
    || date -d "@$early" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null \
    || echo "")
  if [[ -n "$early_ts" ]]; then
    cat > "$proj/session.jsonl" <<EOF
{"message":{"role":"user","content":"throwaway"}}
{"timestamp":"$early_ts","message":{"role":"assistant","usage":{"input_tokens":1000,"cache_read_input_tokens":0,"cache_creation_input_tokens":0}}}
{"timestamp":"$(date '+%Y-%m-%dT%H:%M:%SZ')","message":{"role":"assistant","usage":{"input_tokens":190000,"cache_read_input_tokens":0,"cache_creation_input_tokens":0}}}
EOF
    touch -t "$(date '+%Y%m%d%H%M.%S')" "$proj/session.jsonl" 2>/dev/null || true
    out=$(CC_BURN_FIXTURE="$fix" CC_BURN_THRESHOLD=99999 "$HOME/bin/tmux-burn-segment" 2>/dev/null)
    if echo "$out" | grep -q "burn:"; then
      test_pass "renders burn:Nm under threshold with at-risk fixture"
    else
      test_fail "threshold path" "expected 'burn:Nm', got: '$out'"
    fi
    # Cache invalidation: second run (same cache) — must use cached result
    CC_BURN_FIXTURE="$fix" "$HOME/bin/tmux-burn-segment" >/dev/null 2>&1
    test_pass "second run completes (cache hit path)"
  else
    test_pass "at-risk fixture skipped (date -r/-d not available)"
  fi
  rm -rf "$fix"
else
  test_fail "executable present" "$HOME/bin/tmux-burn-segment missing"
fi

# ─── cc-burn-rate ─────────────────────────────────────
section "cc-burn-rate"
if [[ -x "$HOME/bin/cc-burn-rate" ]]; then
  # cc-burn-rate is a pure-bash rewrite (was Python); check bash syntax only.
  if bash -n "$HOME/bin/cc-burn-rate" 2>/dev/null; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # Nonexistent transcript → silent exit 0
  out=$("$HOME/bin/cc-burn-rate" /nonexistent 200000 2>/dev/null)
  if [[ $? -eq 0 && -z "$out" ]]; then
    test_pass "silent exit 0 for missing transcript"
  else
    test_fail "missing-file behavior" "expected silent exit 0"
  fi
else
  test_fail "executable present" "$HOME/bin/cc-burn-rate missing"
fi

section "cc-lock"
if [[ -x "$HOME/bin/cc-lock" ]]; then
  if bash -n "$HOME/bin/cc-lock"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # Unknown command must exit 2 with usage hint
  if "$HOME/bin/cc-lock" bogus-cmd 2>/dev/null; then
    test_fail "bad-cmd exit code" "expected non-zero"
  else
    test_pass "bad-cmd exits non-zero"
  fi
  # Lock round-trip under /tmp lockdir
  lid="test-lock-$$"
  CC_LOCK_DIR="/tmp/cc-lock-test-$$" "$HOME/bin/cc-lock" acquire "$lid" "dummy-sid" 2>/dev/null
  if [[ -f "/tmp/cc-lock-test-$$/locks/$lid" ]]; then
    test_pass "acquire creates lock file"
  else
    test_fail "acquire" "lock file missing"
  fi
  CC_LOCK_DIR="/tmp/cc-lock-test-$$" "$HOME/bin/cc-lock" release "$lid" 2>/dev/null
  if [[ ! -f "/tmp/cc-lock-test-$$/locks/$lid" ]]; then
    test_pass "release removes lock file"
  else
    test_fail "release" "lock file still present"
  fi
  rm -rf "/tmp/cc-lock-test-$$"
  # Second holder blocked: acquire same lid twice with different sid
  CC_LOCK_DIR="/tmp/cc-lock-test2-$$" "$HOME/bin/cc-lock" acquire "$lid" "sid-A" 2>/dev/null
  if CC_LOCK_DIR="/tmp/cc-lock-test2-$$" "$HOME/bin/cc-lock" acquire "$lid" "sid-B" 2>/dev/null; then
    test_fail "double-acquire" "expected non-zero for second holder"
  else
    test_pass "second holder blocked (exit 1)"
  fi
  rm -rf "/tmp/cc-lock-test2-$$"
else
  test_fail "executable present" "$HOME/bin/cc-lock missing"
fi

section "cc-lock-pre-hook"
if [[ -x "$HOME/bin/cc-lock-pre-hook" ]]; then
  if bash -n "$HOME/bin/cc-lock-pre-hook"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # Pre-hook reads JSON from stdin. Feed it a dummy ToolUse event for a
  # non-existent tool — cc-lock must not be called, hook exits 0.
  dummy_json='{"session_id":"sid-test","tool_name":"Bash","tool_input":{}}'
  if echo "$dummy_json" | CC_LOCK_DIR="/tmp/cc-lock-prehook-$$" "$HOME/bin/cc-lock-pre-hook" >/dev/null 2>&1; then
    test_pass "exit 0 for non-lock tool"
  else
    test_fail "non-lock tool" "expected exit 0"
  fi
  rm -rf "/tmp/cc-lock-prehook-$$"
  # cc-lock-stop-hook: reads session_id from stdin JSON, calls release-by-session
  if [[ -x "$HOME/bin/cc-lock-stop-hook" ]]; then
    if bash -n "$HOME/bin/cc-lock-stop-hook"; then
      test_pass "cc-lock-stop-hook bash syntax valid"
    else
      test_fail "cc-lock-stop-hook bash syntax" "parse error"
    fi
    stop_json='{"session_id":"dummy-sid-stop"}'
    if echo "$stop_json" | CC_LOCK_DIR="/tmp/cc-lock-stop-$$" "$HOME/bin/cc-lock-stop-hook" >/dev/null 2>&1; then
      test_pass "cc-lock-stop-hook exit 0 for unknown session"
    else
      test_fail "cc-lock-stop-hook" "expected exit 0 for unknown session"
    fi
    rm -rf "/tmp/cc-lock-stop-$$"
  else
    test_fail "cc-lock-stop-hook executable" "$HOME/bin/cc-lock-stop-hook missing"
  fi
else
  test_fail "executable present" "$HOME/bin/cc-lock-pre-hook missing"
fi

section "cc-brain-sync"
if [[ -x "$HOME/bin/cc-brain-sync" ]]; then
  if bash -n "$HOME/bin/cc-brain-sync"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # --dry-run must not modify any files
  before=$(git -C "$HOME/dev/dotfiles" status --short 2>/dev/null | wc -l | tr -d ' ')
  "$HOME/bin/cc-brain-sync" --dry-run >/dev/null 2>&1 || true
  after=$(git -C "$HOME/dev/dotfiles" status --short 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$before" == "$after" ]]; then
    test_pass "--dry-run leaves working tree unchanged"
  else
    test_fail "dry-run safety" "working tree changed (before=$before after=$after)"
  fi
  # --help or -h must not fail
  if "$HOME/bin/cc-brain-sync" --help >/dev/null 2>&1; then
    test_pass "--help exits 0"
  else
    test_fail "--help" "non-zero exit"
  fi
else
  test_fail "executable present" "$HOME/bin/cc-brain-sync missing"
fi

section "claude-grep"
if [[ -x "$HOME/bin/claude-grep" ]]; then
  if bash -n "$HOME/bin/claude-grep"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # --help must exit 0 and print usage
  out=$("$HOME/bin/claude-grep" --help 2>&1)
  if echo "$out" | grep -qi "usage\|pattern\|session"; then
    test_pass "--help prints usage"
  else
    test_fail "--help" "no usage text in: $out"
  fi
  # No args → usage on stderr, exit 1
  if "$HOME/bin/claude-grep" 2>/dev/null; then
    test_fail "no-args exit code" "expected non-zero"
  else
    test_pass "no-args exits non-zero"
  fi
  # Pattern with no sessions dir → empty results, exit 0
  out=$(CLAUDE_PROJECTS="/nonexistent" "$HOME/bin/claude-grep" somepattern 2>/dev/null)
  if [[ $? -eq 0 ]]; then
    test_pass "graceful exit when projects dir absent"
  else
    test_fail "absent-projects dir" "expected exit 0"
  fi
else
  test_fail "executable present" "$HOME/bin/claude-grep missing"
fi

# ─── cs-here filter (zshrc function) ──────────────────
section "cs-here"
if grep -qE "^cs-here\(\)" "$HOME/.zshrc"; then
  test_pass "function defined in .zshrc"
  # Test filter logic on synthetic data — bypasses fzf and live sessions.
  fixture=$(printf '5s\tlabel\tid1\tpreview\t/foo/bar\n5s\tlabel\tid2\tpreview\t/foo/bar/sub\n5s\tlabel\tid3\tpreview\t/baz\n')
  out=$(echo "$fixture" | awk -F'\t' -v p="/foo/bar" '
    BEGIN { plen = length(p) }
    { if (substr($5, 1, plen) == p) print $3 }
  ')
  if [[ "$out" == "id1
id2" ]]; then
    test_pass "prefix-filter keeps subdirs, drops siblings"
  else
    test_fail "prefix-filter logic" "got: $out"
  fi
else
  test_fail "function defined" "cs-here() not in .zshrc"
fi

# ─── cc-config-sync ───────────────────────────────────
section "cc-config-sync"
if [[ -x "$HOME/bin/cc-config-sync" ]]; then
  if bash -n "$HOME/bin/cc-config-sync"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # Dry-run path must not write or commit anything
  before=$(git -C "$HOME/dev/dotfiles" status --short 2>/dev/null | wc -l | tr -d ' ')
  "$HOME/bin/cc-config-sync" --dry-run >/dev/null 2>&1
  after=$(git -C "$HOME/dev/dotfiles" status --short 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$before" == "$after" ]]; then
    test_pass "--dry-run leaves working tree unchanged"
  else
    test_fail "dry-run safety" "wt changed before=$before after=$after"
  fi
  # Default invocation must NOT push (push only with --push or CC_SYNC_PUSH=1)
  if grep -q "do_push=0" "$HOME/bin/cc-config-sync" \
     && grep -q '\-\-push' "$HOME/bin/cc-config-sync"; then
    test_pass "push opt-in only (no default push)"
  else
    test_fail "push safety" "default behavior may push without flag"
  fi
else
  test_fail "executable present" "$HOME/bin/cc-config-sync missing"
fi

# ─── claude-jump ──────────────────────────────────────
section "claude-jump"
if [[ -x "$HOME/bin/claude-jump" ]]; then
  if bash -n "$HOME/bin/claude-jump"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # Verify it uses tmux switch-client (the jump primitive)
  if grep -q "switch-client" "$HOME/bin/claude-jump"; then
    test_pass "uses tmux switch-client"
  else
    test_fail "switch primitive" "no switch-client reference"
  fi
  # Verify it depends on fzf (picker)
  if grep -q "fzf" "$HOME/bin/claude-jump"; then
    test_pass "uses fzf picker"
  else
    test_fail "fzf integration" "no fzf reference"
  fi
  # Popup-aware parent-client detection (do_switch helper)
  if grep -q "do_switch" "$HOME/bin/claude-jump" \
     && grep -q "switch-client -c" "$HOME/bin/claude-jump"; then
    test_pass "popup-aware do_switch (parent client detection)"
  else
    test_fail "popup awareness" "no do_switch / switch-client -c — popup binding will close without effect"
  fi
else
  test_fail "executable present" "$HOME/bin/claude-jump missing"
fi

# ─── cc-rich + replay shim ────────────────────────────
section "cc-rich"
if [[ -x "$HOME/bin/cc-rich" ]]; then
  if bash -n "$HOME/dev/dotfiles/bin/cc-rich-shim"; then
    test_pass "cc-rich-shim bash syntax"
  else
    test_fail "cc-rich-shim syntax" "parse error"
  fi
  # The Go binary should be installed at ~/.local/bin/cc-rich
  if [[ -x "$HOME/.local/bin/cc-rich" ]]; then
    test_pass "Go binary installed at ~/.local/bin/cc-rich"
  else
    test_fail "Go binary missing" "run: cd ~/dev/dotfiles/cc-rich && make install"
  fi
  # Replay shim
  if bash -n "$HOME/dev/dotfiles/bin/cc-replay-shim"; then
    test_pass "cc-replay-shim bash syntax"
  else
    test_fail "cc-replay-shim syntax" "parse error"
  fi
  # Empty-arg cc-replay-shim should print usage and exit non-zero
  if "$HOME/bin/cc-replay-shim" >/dev/null 2>&1; then
    test_fail "cc-replay-shim usage check" "exited 0 with no args"
  else
    test_pass "cc-replay-shim usage on no args"
  fi
  # Regression: tmux-claude-session --bare must return a full UUID without
  # the "│ claude:" decoration that the legacy/statusline mode emits.
  # Bug history: cc-rich originally parsed the legacy output and broke
  # because it (a) had a leading │ separator and (b) truncated the sid to
  # 8 chars. --bare was added; cc-rich now uses --bare exclusively.
  if tmux info >/dev/null 2>&1; then
    own_tty=$(tmux display-message -p '#{pane_tty}' 2>/dev/null)
    bare=$("$HOME/bin/tmux-claude-session" --bare "$own_tty" 2>/dev/null)
    if [[ -z "$bare" ]]; then
      # No claude on this pane — that's fine, just skip the assertion
      test_pass "tmux-claude-session --bare runs cleanly (no claude on this tty)"
    else
      # When there IS output, it must be a full UUID and contain no │ or "claude:"
      if [[ "$bare" == *"│"* || "$bare" == *"claude:"* ]]; then
        test_fail "tmux-claude-session --bare format" "got decorated output: $bare"
      elif [[ ${#bare} -lt 20 ]]; then
        test_fail "tmux-claude-session --bare length" "got truncated id (len=${#bare}): $bare"
      else
        test_pass "tmux-claude-session --bare returns full undecorated UUID"
      fi
    fi
  else
    test_pass "tmux-claude-session --bare (skipped — no tmux server)"
  fi

  # ── cc-rich-sidebar regression ──
  # Helper that converts the popup binds (R/B/M) into a side-pane via
  # split-window -h, tagged @cc-rich-sidebar so a second invocation
  # toggles it off. Two checks:
  #   1. Helper is present, executable, bash 3.2 syntax-clean
  #   2. Toggle invariant: split + select-pane -T + list-panes filter
  #      + kill-pane round-trip leaves the original pane count intact
  if [[ -x "$HOME/bin/cc-rich-sidebar" ]]; then
    test_pass "cc-rich-sidebar executable at ~/bin/cc-rich-sidebar"
    if bash -n "$HOME/dev/dotfiles/bin/cc-rich-sidebar"; then
      test_pass "cc-rich-sidebar bash syntax"
    else
      test_fail "cc-rich-sidebar syntax" "parse error"
    fi
    # Bad-arg path: must exit 2 with usage
    if "$HOME/bin/cc-rich-sidebar" bogus >/dev/null 2>&1; then
      test_fail "cc-rich-sidebar bad-arg" "exited 0 with bogus mode"
    else
      test_pass "cc-rich-sidebar bad-arg exits non-zero"
    fi
    # Toggle invariant — only when a tmux server is attached.
    # Pane title format is now @cc-rich-sidebar:<mode>:<src> so the
    # helper can swap the sidebar between source panes (R from a
    # different pane = "show me cc-rich for THIS pane") instead of
    # only toggling on/off.
    if tmux info >/dev/null 2>&1; then
      tw=$(tmux new-window -d -P -F '#{window_id}' -n 'cc-sb-test' 'sleep 30' 2>/dev/null)
      if [[ -n "$tw" ]]; then
        sp=$(tmux list-panes -t "$tw" -F '#{pane_id}' | head -1)
        np=$(tmux split-window -t "$sp" -h -l '35%' -P -F '#{pane_id}' 'sleep 30' 2>/dev/null)
        tmux select-pane -t "$np" -T "@cc-rich-sidebar:pane:$sp" 2>/dev/null
        found=$(tmux list-panes -t "$tw" -F '#{pane_id} #{pane_title}' \
                  | awk '$2 ~ /^@cc-rich-sidebar:/ {print $1; exit}')
        if [[ "$found" == "$np" ]]; then
          test_pass "cc-rich-sidebar toggle: title-tag detection works"
        else
          test_fail "cc-rich-sidebar toggle detection" "tag lookup mismatch ($found vs $np)"
        fi
        tmux kill-pane -t "$np" 2>/dev/null
        n=$(tmux list-panes -t "$tw" -F '#{pane_id}' 2>/dev/null | wc -l | tr -d ' ')
        if [[ "$n" == "1" ]]; then
          test_pass "cc-rich-sidebar toggle: kill-pane removes only sidebar"
        else
          test_fail "cc-rich-sidebar toggle off" "expected 1 pane left, got $n"
        fi
        tmux kill-window -t "$tw" 2>/dev/null
      else
        test_pass "cc-rich-sidebar toggle (skipped — could not create test window)"
      fi
    else
      test_pass "cc-rich-sidebar toggle (skipped — no tmux server)"
    fi
  else
    test_fail "cc-rich-sidebar missing" "run: ln -s ~/dev/dotfiles/bin/cc-rich-sidebar ~/bin/"
  fi
else
  test_fail "executable present" "$HOME/bin/cc-rich missing — run install-shim"
fi

# ─── claude-dirty ─────────────────────────────────────
section "claude-dirty"
if [[ -x "$HOME/bin/claude-dirty" ]]; then
  if bash -n "$HOME/bin/claude-dirty"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # Outside a git repo — must exit non-zero with a clear message.
  out=$(cd /tmp && "$HOME/bin/claude-dirty" 2>&1); _rc=$?
  if [[ $_rc -ne 0 ]] && echo "$out" | grep -q "not in a git repo"; then
    test_pass "errors cleanly outside a git repo"
  else
    test_fail "outside-git error" "rc=$_rc msg='$out'"
  fi
  # Clean repo — must report "all clean".
  _td="/tmp/test-claude-dirty-clean-$$"
  rm -rf "$_td"
  mkdir -p "$_td"
  (cd "$_td" && git init -q && git commit --allow-empty -q -m init)
  out=$(cd "$_td" && "$HOME/bin/claude-dirty" 2>&1)
  rm -rf "$_td"
  if echo "$out" | grep -q "all clean"; then
    test_pass "reports 'all clean' in a clean repo"
  else
    test_fail "clean-repo output" "missing 'all clean'; got: $out"
  fi
  # Dirty repo (staged file) — must flag with "!".
  _td="/tmp/test-claude-dirty-dirty-$$"
  rm -rf "$_td"
  mkdir -p "$_td"
  (cd "$_td" && git init -q && git commit --allow-empty -q -m init \
      && echo x > f.txt && git add f.txt)
  out=$(cd "$_td" && "$HOME/bin/claude-dirty" 2>&1)
  rm -rf "$_td"
  if echo "$out" | grep -qF "!"; then
    test_pass "flags dirty worktree with !"
  else
    test_fail "dirty-repo indicator" "missing '!' in: $out"
  fi
else
  test_fail "executable present" "$HOME/bin/claude-dirty missing"
fi

# ─── tmux-mute-indicator ──────────────────────────────
section "tmux-mute-indicator"
if [[ -x "$HOME/bin/tmux-mute-indicator" ]]; then
  if sh -n "$HOME/bin/tmux-mute-indicator"; then
    test_pass "sh syntax valid"
  else
    test_fail "sh syntax" "parse error"
  fi
  # Save and restore the original mute state around the test.
  _was_muted=0
  [[ -f "$HOME/.claude/.muted" ]] && _was_muted=1
  # Unmuted path — output must be empty.
  rm -f "$HOME/.claude/.muted"
  out=$("$HOME/bin/tmux-mute-indicator" 2>/dev/null)
  if [[ -z "$out" ]]; then
    test_pass "empty output when not muted"
  else
    test_fail "unmuted output" "expected empty, got: $out"
  fi
  # Muted path — output must contain 🔇.
  touch "$HOME/.claude/.muted"
  out=$("$HOME/bin/tmux-mute-indicator" 2>/dev/null)
  if printf '%s' "$out" | grep -qF "🔇"; then
    test_pass "shows 🔇 glyph when muted"
  else
    test_fail "muted output" "missing 🔇 in: $out"
  fi
  # Restore original state.
  if [[ $_was_muted -eq 1 ]]; then touch "$HOME/.claude/.muted"
  else rm -f "$HOME/.claude/.muted"; fi
else
  test_fail "executable present" "$HOME/bin/tmux-mute-indicator missing"
fi

# ─── tmux-resurrect-housekeep ─────────────────────────
section "tmux-resurrect-housekeep"
if [[ -x "$HOME/bin/tmux-resurrect-housekeep" ]]; then
  if bash -n "$HOME/bin/tmux-resurrect-housekeep"; then
    test_pass "bash syntax valid"
  else
    test_fail "bash syntax" "parse error"
  fi
  # KEEP=999999 is safe: nothing will be pruned regardless of actual state.
  out=$(VERBOSE=1 "$HOME/bin/tmux-resurrect-housekeep" 999999 2>&1); _rc=$?
  if [[ $_rc -eq 0 ]]; then
    test_pass "exits 0 with safe KEEP=999999 (no prune)"
  else
    test_fail "exit code (safe KEEP)" "expected 0, got $_rc"
  fi
  # VERBOSE flag must be wired (grep the installed script, fall back to repo).
  _src="$HOME/bin/tmux-resurrect-housekeep"
  if grep -q 'VERBOSE' "$_src"; then
    test_pass "VERBOSE env var supported"
  else
    test_fail "VERBOSE support" "not found in installed script"
  fi
else
  test_fail "executable present" "$HOME/bin/tmux-resurrect-housekeep missing"
fi

# ─── Summary ──────────────────────────────────────────
total=$((PASS + FAIL))
printf "\n${C}──────────────────────────────────────────────${N}\n"
printf "  ${G}PASS${N} %d   ${R}FAIL${N} %d   (total %d)\n" "$PASS" "$FAIL" "$total"

if [[ $FAIL -gt 0 ]]; then
  exit 1
fi
exit 0
