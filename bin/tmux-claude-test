#!/usr/bin/env bash
# tmux-claude-test — regression tests for claude-tmux-ghostty bin/ scripts.
# Tests that need zsh or a live tmux session are skipped when unavailable.
# Exit: 0 = all tests passed (SKIP is not failure), 1 = any FAIL

set -u

REPO="$(cd "$(dirname "$0")/.." && pwd)"
PASS=0; FAIL=0; SKIP=0

_ok()   { PASS=$((PASS+1)); printf '\033[32m[PASS]\033[0m %s\n' "$1"; }
_skip() { SKIP=$((SKIP+1)); printf '[SKIP] %s\n' "$1"; }
_head() { printf '\n\033[1m%s\033[0m\n' "$1"; }

_assert_contains() {
  local label="$1" needle="$2" haystack="$3"
  if printf '%s' "$haystack" | grep -qF "$needle"; then
    _ok "$label"
  else
    FAIL=$((FAIL+1))
    printf '\033[31m[FAIL]\033[0m %s\n' "$label"
    printf '       expected to contain: %s\n' "$needle"
    printf '       got: %s\n' "$haystack"
  fi
}

_assert_not_contains() {
  local label="$1" needle="$2" haystack="$3"
  if ! printf '%s' "$haystack" | grep -qF "$needle"; then
    _ok "$label"
  else
    FAIL=$((FAIL+1))
    printf '\033[31m[FAIL]\033[0m %s\n' "$label"
    printf '       expected NOT to contain: %s\n' "$needle"
    printf '       got: %s\n' "$haystack"
  fi
}

# Detect available tools
HAS_ZSH=0; command -v zsh >/dev/null 2>&1 && HAS_ZSH=1
HAS_JQ=0;  command -v jq  >/dev/null 2>&1 && HAS_JQ=1
HAS_GIT=0; command -v git >/dev/null 2>&1 && HAS_GIT=1

# ─────────────────────────────────────────────────────────────────────────────
# statusline-command.sh — pure sh, needs jq
# ─────────────────────────────────────────────────────────────────────────────
_head "statusline-command.sh"

if [ "$HAS_JQ" -eq 0 ]; then
  _skip "statusline-command.sh (jq not available)"
else
  _SL="$REPO/claude/statusline-command.sh"

  # 1. user@host appears
  _out=$(printf '{"workspace":{"current_dir":"/tmp"},"model":{"display_name":"claude-opus-4"},"context_window":{"used_percentage":30}}' \
    | sh "$_SL" 2>/dev/null)
  _assert_contains "statusline: user@host present" "@" "$_out"

  # 2. model name present
  _assert_contains "statusline: model name present" "claude-opus-4" "$_out"

  # 3. ctx percentage present
  _assert_contains "statusline: ctx percentage present" "ctx:30%" "$_out"

  # 4. session_name renders in brackets when provided
  _out=$(printf '{"workspace":{"current_dir":"/tmp"},"model":{"display_name":"opus"},"context_window":{"used_percentage":10},"session_name":"mywork"}' \
    | sh "$_SL" 2>/dev/null)
  _assert_contains "statusline: session_name renders in brackets" "[mywork]" "$_out"

  # 5. absent session_name → no session bracket in plain text
  # Strip ANSI escape codes before checking — they also contain '[' characters.
  _out=$(printf '{"workspace":{"current_dir":"/tmp"},"model":{"display_name":"opus"},"context_window":{"used_percentage":10}}' \
    | sh "$_SL" 2>/dev/null)
  _plain=$(printf '%s' "$_out" | sed 's/\x1b\[[0-9;]*m//g')
  _assert_not_contains "statusline: absent session_name → no bracket in plain output" "[" "$_plain"

  # 6. ctx ≥ 80 → red \033[31m
  _out=$(printf '{"workspace":{"current_dir":"/tmp"},"model":{"display_name":"opus"},"context_window":{"used_percentage":85}}' \
    | sh "$_SL" 2>/dev/null)
  _RED=$(printf '\033[31m')
  _assert_contains "statusline: ctx≥80 uses red escape \\033[31m" "$_RED" "$_out"

  # 7. ctx 50–79 → yellow \033[33m
  _out=$(printf '{"workspace":{"current_dir":"/tmp"},"model":{"display_name":"opus"},"context_window":{"used_percentage":65}}' \
    | sh "$_SL" 2>/dev/null)
  _YEL=$(printf '\033[33m')
  _assert_contains "statusline: ctx 50–79 uses yellow escape \\033[33m" "$_YEL" "$_out"

  # 8. ctx < 50 → green \033[32m
  _out=$(printf '{"workspace":{"current_dir":"/tmp"},"model":{"display_name":"opus"},"context_window":{"used_percentage":20}}' \
    | sh "$_SL" 2>/dev/null)
  _GRN=$(printf '\033[32m')
  _assert_contains "statusline: ctx<50 uses green escape \\033[32m" "$_GRN" "$_out"

  # 9. empty JSON input does not crash
  _exitcode=0
  printf '{}' | sh "$_SL" >/dev/null 2>&1 || _exitcode=$?
  if [ "$_exitcode" -eq 0 ]; then
    _ok "statusline: empty JSON input does not crash"
  else
    FAIL=$((FAIL+1))
    printf '\033[31m[FAIL]\033[0m statusline: empty JSON crashed with exit %d\n' "$_exitcode"
  fi
fi

# ─────────────────────────────────────────────────────────────────────────────
# tmux-pane-label — bash, needs git
# ─────────────────────────────────────────────────────────────────────────────
_head "tmux-pane-label"

if [ "$HAS_GIT" -eq 0 ]; then
  _skip "tmux-pane-label (git not available)"
else
  _PL="$REPO/bin/tmux-pane-label"

  # 1. non-git path → returns dirname component
  _out=$("$_PL" /tmp 2>/dev/null)
  _assert_contains "tmux-pane-label: non-git path returns 'tmp'" "tmp" "$_out"

  # 2. git repo → output includes repo name and branch (skip if detached HEAD)
  _branch=$(git -C "$REPO" branch --show-current 2>/dev/null)
  if [ -n "$_branch" ]; then
    _out=$("$_PL" "$REPO" 2>/dev/null)
    _assert_contains "tmux-pane-label: git repo output includes branch '$_branch'" "$_branch" "$_out"
  else
    _skip "tmux-pane-label: branch in output (detached HEAD — no current branch)"
  fi

  # 3. branch > 35 chars → truncated with '...'
  _tmpdir=$(mktemp -d)
  git -C "$_tmpdir" init -q 2>/dev/null
  # checkout -b on empty repo sets symbolic HEAD even without commits (git 2.28+)
  git -C "$_tmpdir" checkout -b "a-very-long-branch-name-exceeding-thirty-five-chars" -q 2>/dev/null || true
  _out=$("$_PL" "$_tmpdir" 2>/dev/null)
  if printf '%s' "$_out" | grep -q '\.\.\.'; then
    _ok "tmux-pane-label: branch >35 chars truncated with '...'"
  else
    _skip "tmux-pane-label: long-branch truncation (got: '$_out')"
  fi
  rm -rf "$_tmpdir"
fi

# ─────────────────────────────────────────────────────────────────────────────
# tmux-short-path — zsh required
# ─────────────────────────────────────────────────────────────────────────────
_head "tmux-short-path"

if [ "$HAS_ZSH" -eq 0 ]; then
  _skip "tmux-short-path (zsh not available)"
else
  _SP="$REPO/bin/tmux-short-path"

  # 1. $HOME → ~
  _out=$(zsh "$_SP" "$HOME" 2>/dev/null)
  _assert_contains "tmux-short-path: HOME maps to ~" "~" "$_out"

  # 2. ≤3 path components → unchanged (~/dev/myproject = 3 parts)
  _out=$(zsh "$_SP" "$HOME/dev/myproject" 2>/dev/null)
  _assert_contains "tmux-short-path: 3-component path passes through unabbreviated" "~/dev/myproject" "$_out"

  # 3. deep path (>3 components) → abbreviated with …
  _out=$(zsh "$_SP" "$HOME/a/b/c/d" 2>/dev/null)
  _assert_contains "tmux-short-path: deep path gets … abbreviation" "…" "$_out"
  _assert_contains "tmux-short-path: deep path retains last two components" "c/d" "$_out"

  # 4. worktree path → wt: prefix
  _out=$(zsh "$_SP" "$HOME/dev/.worktrees/my-feature" 2>/dev/null)
  _assert_contains "tmux-short-path: .worktrees/ path → wt:my-feature" "wt:my-feature" "$_out"

  # 5. result ≤ 30 chars (hard cap enforced)
  _out=$(zsh "$_SP" "$HOME/a/b/c/d/verylongdirname/anotherlongdirname" 2>/dev/null)
  _len=${#_out}
  if [ "$_len" -le 30 ]; then
    _ok "tmux-short-path: result hard-capped at 30 chars (got $_len)"
  else
    FAIL=$((FAIL+1))
    printf '\033[31m[FAIL]\033[0m tmux-short-path: result exceeds 30 chars (got %d: %s)\n' "$_len" "$_out"
  fi

  # 6. REGRESSION — non-HOME path must NOT use ~/… prefix
  #    Before the fix, /var/folders/abc/def/ghi showed ~/…/def/ghi (misleading)
  _out=$(zsh "$_SP" "/var/folders/abc/def/ghi" 2>/dev/null)
  _assert_not_contains "tmux-short-path: non-HOME path does NOT use ~/… prefix (regression)" "~/…" "$_out"
fi

# ─────────────────────────────────────────────────────────────────────────────
# tmux-git-info — zsh + git required
# ─────────────────────────────────────────────────────────────────────────────
_head "tmux-git-info"

if [ "$HAS_ZSH" -eq 0 ]; then
  _skip "tmux-git-info (zsh not available)"
elif [ "$HAS_GIT" -eq 0 ]; then
  _skip "tmux-git-info (git not available)"
else
  _GI="$REPO/bin/tmux-git-info"

  # 1. non-git directory → empty output
  _out=$(zsh "$_GI" /tmp 2>/dev/null)
  if [ -z "$_out" ]; then
    _ok "tmux-git-info: non-git dir produces empty output"
  else
    FAIL=$((FAIL+1))
    printf '\033[31m[FAIL]\033[0m tmux-git-info: non-git dir should produce empty output, got: %s\n' "$_out"
  fi

  # 2. git repo → non-empty output containing branch name (skip if detached HEAD)
  _branch=$(git -C "$REPO" branch --show-current 2>/dev/null)
  if [ -n "$_branch" ]; then
    _out=$(zsh "$_GI" "$REPO" 2>/dev/null)
    _assert_contains "tmux-git-info: git repo output includes branch name" "$_branch" "$_out"
  else
    _skip "tmux-git-info: branch in output (detached HEAD)"
  fi
fi

# ─────────────────────────────────────────────────────────────────────────────
# tmux-session-list — needs to run inside a live tmux session
# ─────────────────────────────────────────────────────────────────────────────
_head "tmux-session-list"

if [ -z "${TMUX:-}" ]; then
  _skip "tmux-session-list (not inside a tmux session — run from within tmux to test)"
else
  _current=$(tmux display-message -p '#S' 2>/dev/null)
  _out=$(bash "$REPO/bin/tmux-session-list" "$_current" 2>/dev/null)
  # Active session gets hex bg #7C3AED (hardcoded in the script)
  _assert_contains "tmux-session-list: active session gets highlighted bg #7C3AED" "#7C3AED" "$_out"
fi

# ─────────────────────────────────────────────────────────────────────────────
# Summary
# ─────────────────────────────────────────────────────────────────────────────
printf '\n'
printf 'Tests complete — %d PASS / %d FAIL / %d SKIP\n' "$PASS" "$FAIL" "$SKIP"
printf '\n'

[ "$FAIL" -eq 0 ]
