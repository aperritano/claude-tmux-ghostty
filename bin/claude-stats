#!/usr/bin/env python3
"""
claude-stats — token usage across recent Claude Code sessions.

Walks ~/.claude/projects/*/*.jsonl modified within the time window, sums
.message.usage from assistant turns, surfaces totals + top sessions.

Usage:
  claude-stats              # today
  claude-stats --days 3     # last 3 days
  claude-stats --top 10     # top 10 sessions (default 5)
"""

from __future__ import annotations

import argparse
import json
import os
import sys
from collections import defaultdict
from datetime import datetime, time as dtime, timedelta
from pathlib import Path

PROJECTS = Path(os.environ.get("CLAUDE_PROJECTS", str(Path.home() / ".claude" / "projects")))
HOME = str(Path.home())

C = "\033[36m"
Y = "\033[33m"
G = "\033[32m"
DIM = "\033[90m"
N = "\033[0m"


def short_label(p: str) -> str:
    if p.startswith(HOME):
        p = "~" + p[len(HOME):]
    if "/.worktrees/" in p:
        repo = p.split("/.worktrees/")[0].rsplit("/", 1)[-1]
        wt = p.split("/.worktrees/")[1].split("/")[0]
        if len(wt) > 24:
            wt = wt[:21] + "..."
        return f"{repo}:wt/{wt}"
    parts = p.rstrip("/").split("/")
    return f"{parts[-2]}/{parts[-1]}" if len(parts) >= 2 else p


def fmt(n: int) -> str:
    return f"{n:,}"


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--days", type=int, default=1)
    ap.add_argument("--top", type=int, default=5)
    args = ap.parse_args()

    cutoff = datetime.combine(datetime.now().date(), dtime.min) - timedelta(days=args.days - 1)

    if not PROJECTS.is_dir():
        return 0

    sessions: dict[str, dict] = defaultdict(
        lambda: {"in": 0, "out": 0, "cache_r": 0, "cache_c": 0, "cwd": "", "msgs": 0}
    )
    sessions_scanned = 0

    for jsonl in PROJECTS.glob("*/*.jsonl"):
        try:
            mtime = datetime.fromtimestamp(jsonl.stat().st_mtime)
        except OSError:
            continue
        if mtime < cutoff:
            continue
        sessions_scanned += 1
        sid = jsonl.stem[:8]
        try:
            with jsonl.open(encoding="utf-8", errors="replace") as f:
                for line in f:
                    if not line.strip():
                        continue
                    try:
                        obj = json.loads(line)
                    except json.JSONDecodeError:
                        continue
                    if not sessions[sid]["cwd"] and obj.get("cwd"):
                        sessions[sid]["cwd"] = obj["cwd"]
                    if obj.get("type") != "assistant":
                        continue
                    usage = (obj.get("message") or {}).get("usage") or {}
                    sessions[sid]["in"] += usage.get("input_tokens", 0) or 0
                    sessions[sid]["out"] += usage.get("output_tokens", 0) or 0
                    sessions[sid]["cache_r"] += usage.get("cache_read_input_tokens", 0) or 0
                    sessions[sid]["cache_c"] += usage.get("cache_creation_input_tokens", 0) or 0
                    sessions[sid]["msgs"] += 1
        except OSError:
            continue

    if not sessions:
        label = "today" if args.days == 1 else f"last {args.days} days"
        print(f"  {DIM}No assistant token data {label}.{N}")
        return 0

    totals = {k: sum(s[k] for s in sessions.values()) for k in ("in", "out", "cache_r", "cache_c")}
    total_msgs = sum(s["msgs"] for s in sessions.values())
    grand = sum(totals.values())

    days_label = "today" if args.days == 1 else f"last {args.days} days"
    print(f"{C}── token usage — {days_label} ──{N}")
    print(f"  {DIM}{sessions_scanned} sessions, {total_msgs} assistant turns{N}\n")

    print(f"  input tokens:       {Y}{fmt(totals['in']):>14}{N}")
    print(f"  output tokens:      {Y}{fmt(totals['out']):>14}{N}")
    print(f"  cache reads:        {DIM}{fmt(totals['cache_r']):>14}{N}")
    print(f"  cache creates:      {DIM}{fmt(totals['cache_c']):>14}{N}")
    print(f"  {DIM}─────────────────────────────────{N}")
    print(f"  effective input:    {fmt(totals['in'] + totals['cache_r'] + totals['cache_c']):>14}")
    print(f"  total processed:    {G}{fmt(grand):>14}{N}")
    print()

    cache_savings_pct = (totals["cache_r"] / max(totals["cache_r"] + totals["in"] + totals["cache_c"], 1)) * 100
    print(f"  {DIM}cache hit rate: {cache_savings_pct:.1f}% of input tokens served from cache{N}")
    print()

    print(f"{C}── top {args.top} sessions by total tokens ──{N}")
    top = sorted(sessions.items(), key=lambda x: -sum(v for k, v in x[1].items() if k not in ("cwd", "msgs")))[:args.top]
    for sid, s in top:
        total_s = s["in"] + s["out"] + s["cache_r"] + s["cache_c"]
        label = short_label(s["cwd"]) if s["cwd"] else "(unknown)"
        print(f"  {Y}{fmt(total_s):>12}{N}  {sid}  {DIM}{label}{N}  {s['msgs']} turns")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
