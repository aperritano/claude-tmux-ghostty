#!/usr/bin/env bash
# cc-rich-sidebar — toggle a cc-rich sidebar in the current tmux window.
#
# Replaces the prior display-popup binds. Splits the window horizontally
# (side-by-side), runs cc-rich in the new pane, and tags the pane title with
# @cc-rich-sidebar so a second invocation can find and close it (toggle).
#
# Bash 3.2 portable (macOS default). No mapfile, no associative arrays.
#
# Usage:
#   cc-rich-sidebar pane <source-pane-id>     # --pane mode against given pane
#   cc-rich-sidebar browse                    # --browse mode (no pane arg)
#   cc-rich-sidebar merge <source-pane-id>    # --merge-into mode

set -uo pipefail

mode="${1:-}"
src="${2:-}"

case "$mode" in
  pane|browse|merge) ;;
  *)
    echo "usage: cc-rich-sidebar pane|browse|merge [<source-pane-id>]" >&2
    exit 2
    ;;
esac

# Width as a tmux size spec. 35% gives readable transcript without crowding
# the source pane. Override with CC_RICH_SIDEBAR_PCT in env if needed.
pct="${CC_RICH_SIDEBAR_PCT:-35}"

# Pane title format: @cc-rich-sidebar:<mode>:<src>
# Search ALL windows (-a) — a sidebar in another tmux window must
# still be detected and reaped/moved when R is pressed from the
# current window. Without -a the helper would silently spawn a second
# sidebar each time the user switched windows.
#
# Decision matrix (with the existing sidebar's window vs current window):
#   - none anywhere               → spawn new (fall through)
#   - current focus IS the sidebar → close (toggle off via guard below)
#   - same window, same tag        → close (user wants to dismiss)
#   - same window, different tag   → replace (different source pane)
#   - different window             → bring sidebar HERE (kill old, spawn new)
want_tag="@cc-rich-sidebar:${mode}:${src}"

# Collect EVERY tagged sidebar pane across all windows. Old buggy
# versions could leave orphans behind; matching with prefix
# /^@cc-rich-sidebar/ also catches pre-2026-05-04 untagged-source
# titles ("@cc-rich-sidebar" with no suffix).
all_existing=$(tmux list-panes -a -F '#{window_id} #{pane_id} #{pane_title}' 2>/dev/null \
                  | awk '$3 ~ /^@cc-rich-sidebar/ {print $1 ":" $2 ":" $3}')

current_window=$(tmux display-message -p '#{window_id}' 2>/dev/null)
current_pane=$(tmux display-message -p '#{pane_id}' 2>/dev/null)

if [[ -n "$all_existing" ]]; then
  # Decide toggle vs replace based on the FIRST entry — but kill
  # every entry we find, so orphans get reaped on every keypress.
  first=$(echo "$all_existing" | head -1)
  first_window=$(echo "$first" | awk -F: '{print $1}')
  first_pane=$(echo "$first" | awk -F: '{print $2}')
  first_tag=$(echo "$first" | cut -d: -f3-)

  toggle_off=0
  if [[ "$current_pane" == "$first_pane" ]]; then
    toggle_off=1  # user pressed R from inside the sidebar
  elif [[ "$first_window" == "$current_window" && "$first_tag" == "$want_tag" ]]; then
    toggle_off=1  # same window + same source = "close it"
  fi

  # Kill every tagged sidebar (handles multi-window orphan cleanup).
  echo "$all_existing" | while IFS=: read -r _ pid _; do
    tmux kill-pane -t "$pid" 2>/dev/null
  done

  if [[ "$toggle_off" -eq 1 ]]; then
    exit 0
  fi
  # Otherwise fall through: spawn a fresh sidebar for THIS pane.
fi

# Build the cc-rich invocation. Always full path — like the prior popup
# binds, the spawned shell does NOT source ~/.zshrc, so ~/bin is not on
# PATH. (See cc-rich/CLAUDE.md "Gotchas" for the history of this trap.)
case "$mode" in
  pane)
    if [[ -z "$src" ]]; then
      echo "cc-rich-sidebar pane: missing source pane id" >&2
      exit 2
    fi
    cmd="$HOME/bin/cc-rich --pane $src"
    ;;
  browse)
    cmd="$HOME/bin/cc-rich --browse"
    ;;
  merge)
    if [[ -z "$src" ]]; then
      echo "cc-rich-sidebar merge: missing source pane id" >&2
      exit 2
    fi
    cmd="$HOME/bin/cc-rich --merge-into $src"
    ;;
esac

# split-window: -h = horizontal split (side-by-side panes, sidebar on the
# right). -l <pct>% sizes the new pane. -P prints the new pane id so we can
# tag its title for toggle detection on the next invocation.
new_pane=$(tmux split-window -h -l "${pct}%" -P -F '#{pane_id}' "$cmd")
if [[ -n "$new_pane" ]]; then
  tmux select-pane -t "$new_pane" -T "$want_tag"
fi
