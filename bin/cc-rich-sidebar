#!/usr/bin/env bash
# cc-rich-sidebar — toggle a cc-rich sidebar in the current tmux window.
#
# Replaces the prior display-popup binds. Splits the window horizontally
# (side-by-side), runs cc-rich in the new pane, and tags the pane title with
# @cc-rich-sidebar so a second invocation can find and close it (toggle).
#
# Bash 3.2 portable (macOS default). No mapfile, no associative arrays.
#
# Usage:
#   cc-rich-sidebar pane <source-pane-id>     # --pane mode against given pane
#   cc-rich-sidebar browse                    # --browse mode (no pane arg)
#   cc-rich-sidebar merge <source-pane-id>    # --merge-into mode

set -uo pipefail

mode="${1:-}"
src="${2:-}"

case "$mode" in
  pane|browse|merge) ;;
  *)
    echo "usage: cc-rich-sidebar pane|browse|merge [<source-pane-id>]" >&2
    exit 2
    ;;
esac

# Width as a tmux size spec. 35% gives readable transcript without crowding
# the source pane. Override with CC_RICH_SIDEBAR_PCT in env if needed.
pct="${CC_RICH_SIDEBAR_PCT:-35}"

# Pane title format: @cc-rich-sidebar:<mode>:<src>
# - Same mode+src as existing → toggle off (kill).
# - Different mode/src → replace (kill old, fall through to spawn new).
# This makes R "show cc-rich for the focused pane" — pressing R from a
# different pane swaps the sidebar over to that pane's session instead
# of just closing it.
want_tag="@cc-rich-sidebar:${mode}:${src}"
existing_line=$(tmux list-panes -F '#{pane_id} #{pane_title}' 2>/dev/null \
                  | awk '$2 ~ /^@cc-rich-sidebar:/ {print $1, $2; exit}')
if [[ -n "$existing_line" ]]; then
  existing_pane=${existing_line%% *}
  existing_tag=${existing_line#* }
  # If the user pressed R/B/M from inside the sidebar pane itself, do
  # nothing — otherwise we'd kill the pane while it's focused and tmux
  # would land them on a sibling unexpectedly.
  current_pane=$(tmux display-message -p '#{pane_id}' 2>/dev/null)
  if [[ "$current_pane" == "$existing_pane" ]]; then
    tmux kill-pane -t "$existing_pane"
    exit 0
  fi
  if [[ "$existing_tag" == "$want_tag" ]]; then
    # Same mode + same source pane → toggle off.
    tmux kill-pane -t "$existing_pane"
    exit 0
  fi
  # Different source — replace.
  tmux kill-pane -t "$existing_pane"
fi

# Build the cc-rich invocation. Always full path — like the prior popup
# binds, the spawned shell does NOT source ~/.zshrc, so ~/bin is not on
# PATH. (See cc-rich/CLAUDE.md "Gotchas" for the history of this trap.)
case "$mode" in
  pane)
    if [[ -z "$src" ]]; then
      echo "cc-rich-sidebar pane: missing source pane id" >&2
      exit 2
    fi
    cmd="$HOME/bin/cc-rich --pane $src"
    ;;
  browse)
    cmd="$HOME/bin/cc-rich --browse"
    ;;
  merge)
    if [[ -z "$src" ]]; then
      echo "cc-rich-sidebar merge: missing source pane id" >&2
      exit 2
    fi
    cmd="$HOME/bin/cc-rich --merge-into $src"
    ;;
esac

# split-window: -h = horizontal split (side-by-side panes, sidebar on the
# right). -l <pct>% sizes the new pane. -P prints the new pane id so we can
# tag its title for toggle detection on the next invocation.
new_pane=$(tmux split-window -h -l "${pct}%" -P -F '#{pane_id}' "$cmd")
if [[ -n "$new_pane" ]]; then
  tmux select-pane -t "$new_pane" -T "$want_tag"
fi
