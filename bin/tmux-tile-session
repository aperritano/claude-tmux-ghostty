#!/usr/bin/env bash
# tmux-tile-session — toggle between tiled panes and tabbed windows
# Usage: tmux-tile-session [tile|untile|toggle]
#
# tile:   joins all windows in the session into one window as tiled panes
# untile: breaks each pane back into its own window (restores tab names)
# toggle: auto-detects current state (default)

set -euo pipefail

action=${1:-toggle}
session=$(tmux display-message -p '#{session_name}')

is_tiled() {
  [ "$(tmux show-option -qv -t "$session" @tiled)" = "1" ]
}

tile() {
  local windows count target

  windows=$(tmux list-windows -t "$session" -F '#{window_index}:#{window_name}')
  count=$(echo "$windows" | wc -l | tr -d ' ')

  if [ "$count" -le 1 ]; then
    tmux display-message "Only 1 window — nothing to tile"
    exit 0
  fi

  target=$(echo "$windows" | head -1 | cut -d: -f1)
  local target_pane
  target_pane=$(tmux list-panes -t "$session:$target" -F '#{pane_id}' | head -1)

  # Tag each pane with its original window name and position for restore
  local position=0
  while IFS=: read -r idx name; do
    for pane_id in $(tmux list-panes -t "$session:$idx" -F '#{pane_id}'); do
      tmux set-option -p -t "$pane_id" @orig_name "$name"
      tmux set-option -p -t "$pane_id" @orig_pos "$position"
    done
    position=$((position + 1))
  done <<< "$windows"

  # Join all other windows into the target (reverse order preserves visual order)
  local other_indices
  other_indices=$(echo "$windows" | tail -n +2 | tail -r | cut -d: -f1)

  for idx in $other_indices; do
    while tmux list-panes -t "$session:$idx" -F '#{pane_id}' 2>/dev/null | head -1 | grep -q .; do
      tmux join-pane -s "$session:$idx" -t "$session:$target" 2>/dev/null || break
    done
  done

  # Prefer side-by-side (vertical splits). Use even-horizontal for up to 3 panes,
  # fall back to tiled grid for 4+ (which still favors columns over rows).
  local pane_count
  pane_count=$(tmux list-panes -t "$session:$target" | wc -l | tr -d ' ')
  if [ "$pane_count" -le 3 ]; then
    tmux select-layout -t "$session:$target" even-horizontal
  else
    tmux select-layout -t "$session:$target" tiled
  fi
  # Re-select the original first pane so untile restores names correctly
  tmux select-pane -t "$target_pane"
  tmux set-option -t "$session" @tiled 1
  tmux rename-window "tiled ($count)"
  tmux display-message "Tiled $count windows — Ctrl-a E to restore"
}

untile() {
  local panes count current

  panes=$(tmux list-panes -F '#{pane_id}')
  count=$(echo "$panes" | wc -l | tr -d ' ')

  if [ "$count" -le 1 ]; then
    tmux display-message "Only 1 pane — nothing to untile"
    exit 0
  fi

  current=$(tmux display-message -p '#{pane_id}')

  # Sort panes by original position so names restore to correct windows
  local sorted_panes
  sorted_panes=$(for pane in $panes; do
    pos=$(tmux show-option -pqv -t "$pane" @orig_pos || true)
    echo "${pos:-999} $pane"
  done | sort -n | awk '{print $2}')

  # The first pane (lowest position) stays in the current window
  local first_pane
  first_pane=$(echo "$sorted_panes" | head -1)

  # If we're not on the first pane, switch to it so names restore correctly
  if [ "$current" != "$first_pane" ]; then
    tmux select-pane -t "$first_pane"
  fi

  # Break every pane except the first into its own window
  for pane in $(echo "$sorted_panes" | tail -n +2); do
    local orig
    orig=$(tmux show-option -pqv -t "$pane" @orig_name || true)
    tmux break-pane -d -s "$pane" -n "${orig:-restored}"
  done

  # Restore first pane's window name
  local first_orig
  first_orig=$(tmux show-option -pqv -t "$first_pane" @orig_name || true)
  [ -n "$first_orig" ] && tmux rename-window "$first_orig"

  tmux set-option -t "$session" -u @tiled 2>/dev/null || true
  tmux display-message "Restored $count windows"
}

case "$action" in
  tile)   tile ;;
  untile) untile ;;
  toggle) is_tiled && untile || tile ;;
  *)      echo "Usage: $0 {tile|untile|toggle}" >&2; exit 1 ;;
esac
