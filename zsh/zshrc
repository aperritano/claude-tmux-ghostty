# cw-go — fzf-jump into an existing worktree (no creation).
# Inside tmux: switches to existing window if one is named after the branch,
# otherwise opens a new window in the worktree's path.
# Outside tmux: cd into the worktree.
cw-go() {
  local toplevel main_repo
  toplevel=$(git rev-parse --show-toplevel 2>/dev/null) || {
    echo "cw-go: not in a git repo" >&2
    return 1
  }
  case "$toplevel" in
    */.worktrees/*)        main_repo="${toplevel%%/.worktrees/*}" ;;
    */.claude/worktrees/*) main_repo="${toplevel%%/.claude/worktrees/*}" ;;
    *)                     main_repo="$toplevel" ;;
  esac

  local sel
  sel=$(git -C "$main_repo" worktree list --porcelain | awk '
    /^worktree / { wt=$2; branch=""; next }
    /^branch /   { sub(/refs\/heads\//, "", $2); branch=$2; next }
    /^$/         { if (wt) print wt"\t"branch; wt=""; branch="" }
    END          { if (wt) print wt"\t"branch }
  ' | awk -F'\t' -v main="$main_repo" '$1 != main && $2 != ""' | fzf \
      --delimiter=$'\t' \
      --with-nth=2,1 \
      --reverse \
      --height=60% \
      --prompt='wt> ' \
      --header="select worktree to jump to (branch · path)")

  [[ -z "$sel" ]] && return 0
  local wt branch
  wt=$(echo "$sel" | cut -f1)
  branch=$(echo "$sel" | cut -f2)

  if [[ -n "$TMUX" ]]; then
    # If a tmux window with this branch's name already exists, switch to it.
    local existing
    existing=$(tmux list-windows -F '#{window_name}' 2>/dev/null | grep -F -x "$branch" | head -1)
    if [[ -n "$existing" ]]; then
      tmux select-window -t "$existing"
      print -P "%F{green}→%f switched to existing window: $branch"
    else
      tmux new-window -c "$wt" -n "$branch"
      print -P "%F{green}✓%f opened new window in $wt"
    fi
  else
    cd "$wt"
    print -P "%F{green}→%f $wt"
  fi
}

# cw <branch> [name] — make/find a git worktree, open Claude in it.
# - In tmux: opens a new window named <name|branch>, cd to worktree, runs claude.
# - Outside tmux: cd + claude.
# - Existing branch: creates worktree tracking it.
# - New branch: creates both branch + worktree.
# - Always resolves to the MAIN repo even if invoked from inside a worktree.
cw() {
  if [[ $# -eq 0 ]]; then
    echo "usage: cw <branch> [window-name]" >&2
    return 1
  fi
  local branch="$1"
  local name="${2:-$branch}"

  local toplevel
  toplevel=$(git rev-parse --show-toplevel 2>/dev/null) || {
    echo "cw: not in a git repo" >&2
    return 1
  }

  # Resolve main repo (strip .worktrees/<wt>/ if invoked inside one).
  local main_repo
  if [[ "$toplevel" == *"/.worktrees/"* ]]; then
    main_repo="${toplevel%%/.worktrees/*}"
  else
    main_repo="$toplevel"
  fi

  local wt_path="$main_repo/.worktrees/$branch"

  if [[ ! -d "$wt_path" ]]; then
    if git -C "$main_repo" show-ref --verify --quiet "refs/heads/$branch"; then
      git -C "$main_repo" worktree add "$wt_path" "$branch" || return 1
    else
      git -C "$main_repo" worktree add -b "$branch" "$wt_path" || return 1
    fi
    print -P "%F{green}✓%f worktree created: $wt_path"
  else
    print -P "%F{cyan}→%f worktree already exists: $wt_path"
  fi

  if [[ -n "$TMUX" ]]; then
    tmux new-window -c "$wt_path" -n "$name" "claude"
  else
    cd "$wt_path" && claude
  fi
}
# Picks one → cd to its project + claude --resume <session-id>.
# cs-grep — content-level search across transcripts (one row per matching TURN).
# Where cs-find returns one row per session, cs-grep returns one row per turn,
# so you can scan WHICH turn matched, not just which session. --here scopes
# to sessions whose cwd is under $PWD.
cs-grep() {
  if [[ $# -eq 0 ]]; then
    echo "usage: cs-grep [--here] <query>" >&2
    return 1
  fi
  local sel
  sel=$(~/bin/claude-grep "$@" 2>&1 | fzf \
    --delimiter=$'\t' \
    --with-nth=1,2,4 \
    --reverse --no-sort --height=100% \
    --preview='echo session: {3}; echo cwd:     {5}; echo; echo {4}' \
    --preview-window=down:6:wrap \
    --header="claude-grep: $* — Enter to resume that session, Esc to cancel")
  [[ -z "$sel" ]] && return 0
  local cwd session
  cwd=$(echo "$sel" | cut -f5 | sed 's/[[:space:]]*$//')
  session=$(echo "$sel" | cut -f3 | tr -d ' ')
  if [[ ! -d "$cwd" ]]; then
    echo "cs-grep: cwd no longer exists: $cwd" >&2
    return 1
  fi
  cd "$cwd" && claude --resume "$session"
}

cs-find() {
  if [[ $# -eq 0 ]]; then
    echo "usage: cs-find <query>" >&2
    return 1
  fi
  local sel
  sel=$(~/bin/claude-search "$@" 2>&1 | fzf \
    --delimiter=$'\t' \
    --with-nth=1,2,4 \
    --reverse --no-sort --height=100% \
    --preview='echo session: {3}; echo cwd:     {5}; echo; echo {4}' \
    --preview-window=down:5:wrap \
    --header="claude-search: $* — Enter to resume, Esc to cancel")
  [[ -z "$sel" ]] && return 0
  local cwd session
  cwd=$(echo "$sel" | cut -f5 | sed 's/[[:space:]]*$//')
  session=$(echo "$sel" | cut -f3 | tr -d ' ')
  if [[ ! -d "$cwd" ]]; then
    echo "cs-find: cwd no longer exists: $cwd" >&2
    return 1
  fi
  cd "$cwd" && claude --resume "$session"
}
# `cc` (named tab launcher) is defined as a function below — don't shadow it.

# tmux-claude-health: one-shot status report for the tmux-claude-save stack.
# Shows: continuum auto-save freshness, sidecar entries, recent saves, total sessions.
tmux-claude-health() {
  local R="$HOME/.tmux/resurrect"
  local last_save="$R/last"
  if [[ ! -L "$last_save" ]]; then
    echo "no resurrect saves yet — run prefix+Ctrl-s once to seed"
    return 1
  fi
  local resolved
  resolved=$(readlink "$last_save")
  local age_sec=$(( $(date +%s) - $(stat -f %m "$R/$resolved" 2>/dev/null || echo 0) ))
  local age_str
  if   [[ $age_sec -lt 60   ]]; then age_str="${age_sec}s ago"
  elif [[ $age_sec -lt 3600 ]]; then age_str="$((age_sec/60))m ago"
  else                               age_str="$((age_sec/3600))h ago"
  fi
  print -P "%F{yellow}── tmux-claude-save status ─────────────%f"
  print -P "  last save:    %F{cyan}$resolved%f  ($age_str)"
  print -P "  saves on disk: %F{cyan}$(ls "$R"/tmux_resurrect_*.txt 2>/dev/null | wc -l | tr -d ' ')%f"
  print -P "  sidecar entries: %F{cyan}$(wc -l < "$R/claude-state.txt" 2>/dev/null | tr -d ' ')%f"
  print -P "  total claude sessions on disk: %F{cyan}$(find ~/.claude/projects -name '*.jsonl' -type f 2>/dev/null | wc -l | tr -d ' ')%f"
  local color verdict
  if [[ $age_sec -gt 360 ]]; then color=red; verdict=STALE; else color=green; verdict=OK; fi
  print -P "  continuum interval: %F{cyan}5m%f  (warn if > 6m: %F{${color}}${verdict}%f)"
}

# bat — syntax-highlighted cat. Uses ANSI palette so it adapts to whichever
# iTerm profile is active. `cat` aliases to plain mode (no gutter, no paging,
# but with colors). Use `bat <file>` directly for line numbers + paging.
