# cc-mute — silence all Claude hook sounds (Glass/Pop/Funk/Tink/Submarine).
# Useful during meetings or focus blocks. Visual notifications still fire.
#   cc-mute            → toggle (default)
#   cc-mute on         → mute
#   cc-mute off        → unmute
#   cc-mute status     → show state
cc-mute() {
  local flag="$HOME/.claude/.muted"
  case "${1:-toggle}" in
    on)
      touch "$flag"
      print -P "%F{yellow}🔇 hooks muted%f"
      ;;
    off)
      rm -f "$flag"
      print -P "%F{green}🔊 hooks unmuted%f"
      ;;
    status)
      if [[ -f "$flag" ]]; then
        print -P "%F{yellow}🔇 muted%f"
      else
        print -P "%F{green}🔊 unmuted%f"
      fi
      ;;
    toggle|"")
      if [[ -f "$flag" ]]; then
        rm -f "$flag"
        print -P "%F{green}🔊 hooks unmuted%f"
      else
        touch "$flag"
        print -P "%F{yellow}🔇 hooks muted%f"
      fi
      ;;
    *)
      echo "usage: cc-mute [on|off|status|toggle]" >&2
      return 1
      ;;
  esac
}

# cc-doctor — full health check: audit (wiring) + test (runtime) + fix (auto-resolve).
# Three-step: each step's summary is collected so you see the whole picture in one screen.
cc-doctor() {
  print -P "%F{cyan}%B═══ cc-doctor: full health check ═══%b%f"
  print

  print -P "%F{yellow}%B▸ audit — configuration wiring%b%f"
  ~/bin/tmux-claude-audit --quiet 2>&1 | tail -3 | sed 's/^/  /'
  print

  print -P "%F{yellow}%B▸ test — runtime correctness%b%f"
  ~/bin/tmux-claude-test 2>&1 | tail -3 | sed 's/^/  /'
  print

  print -P "%F{yellow}%B▸ fix — auto-resolve fixable warns%b%f"
  cc-fix 2>&1 | grep -vE "^── (cc-fix|re-running)" | sed 's/^/  /'
}

# cc-fix — auto-resolve the auto-resolvable WARNs from cc-audit.
# Currently handles: stale continuum save (forces an immediate save).
# Doesn't touch destructive things (won't auto-commit dotfiles).
cc-fix() {
  print -P "%F{cyan}── cc-fix: auto-resolve fixable warns ──%f"
  local fixed=0

  # 1. Stale continuum save → force one
  local last="$HOME/.tmux/resurrect/last"
  if [[ -L "$last" ]]; then
    local resolved age_sec
    resolved=$(readlink "$last")
    age_sec=$(( $(date +%s) - $(stat -f %m "$HOME/.tmux/resurrect/$resolved" 2>/dev/null || echo 0) ))
    if [[ $age_sec -gt 360 ]] && tmux info >/dev/null 2>&1; then
      tmux run-shell '~/.tmux/plugins/tmux-resurrect/scripts/save.sh' >/dev/null 2>&1
      print -P "  %F{green}✓%f forced continuum save (was $((age_sec/60))m old)"
      fixed=$((fixed+1))
    fi
  fi

  # 2. Dotfiles uncommitted — surface but don't auto-commit (CLAUDE.md says not to)
  local DOTS="$HOME/dev/dotfiles"
  if [[ -d "$DOTS/.git" ]]; then
    local porcelain
    porcelain=$(git -C "$DOTS" status --porcelain 2>/dev/null)
    if [[ -n "$porcelain" ]]; then
      local count
      count=$(printf '%s\n' "$porcelain" | wc -l | awk '{print $1}')
      print -P "  %F{yellow}!%f dotfiles has $count uncommitted entries — skipped (run 'git -C ~/dev/dotfiles status' to inspect)"
    fi
  fi

  if [[ $fixed -eq 0 ]]; then
    print -P "  %F{8}nothing to fix automatically.%f"
  fi
  print -P "%F{cyan}── re-running audit ──%f"
  ~/bin/tmux-claude-audit --quiet 2>&1 | tail -3
}

