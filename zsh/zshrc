# cc-test-sounds — verify all 4 Claude hook sounds play. Useful to confirm
# audio is wired correctly without waiting for an actual hook to fire.
cc-test-sounds() {
  printf '%b\n' '\033[36m── Claude hook sounds ──\033[0m'
  printf '  %-15s %s\n' 'Notification:' 'Glass.aiff (needs your attention)'
  afplay /System/Library/Sounds/Glass.aiff & wait
  sleep 0.4
  printf '  %-15s %s\n' 'Stop:' 'Pop.aiff (turn complete)'
  afplay /System/Library/Sounds/Pop.aiff & wait
  sleep 0.4
  printf '  %-15s %s\n' 'StopFailure:' 'Funk.aiff (turn errored)'
  afplay /System/Library/Sounds/Funk.aiff & wait
  sleep 0.4
  printf '  %-15s %s\n' 'PreCompact:' 'Tink.aiff (compaction warning)'
  afplay /System/Library/Sounds/Tink.aiff & wait
  sleep 0.4
  printf '  %-15s %s\n' 'SubagentStop:' 'Submarine.aiff @30% (teammate finished)'
  afplay -v 0.3 /System/Library/Sounds/Submarine.aiff & wait
  printf '%b\n' '\033[32mDone — if you heard 5 distinct sounds, hook audio is wired.\033[0m'
}

