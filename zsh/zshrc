# cs-recent [hours] — fzf picker filtered to sessions touched in the last N hours.
# Default: 4 hours (post-lunch resume case). Faster than full picker when you just
# need to resume something recent.
cs-recent() {
  local hours="${1:-4}"
  local max_seconds=$((hours * 3600))
  local sel
  sel=$(~/bin/claude-sessions-list | awk -F'\t' -v max="$max_seconds" '
    {
      age = $1; n = age + 0
      unit = substr(age, length(n) + 1)
      if      (unit == "s") sec = n
      else if (unit == "m") sec = n * 60
      else if (unit == "h") sec = n * 3600
      else if (unit == "d") sec = n * 86400
      else                  sec = 0
      if (sec <= max) print
    }
  ' | awk -F'\t' -v OFS='\t' '{ printf "%-4s\t%-32s\t%s\t%s\t%s\n", $1, $2, $3, $4, $5 }' | fzf \
    --delimiter=$'\t' \
    --with-nth=1,2,4 \
    --header="recent claude sessions (last ${hours}h) — Enter to resume, Esc cancel" \
    --reverse --no-sort --height=80% \
    --prompt='session> ' \
    --preview='echo "session: {3}"; echo "cwd:     {5}"; echo; echo "{4}"' \
    --preview-window=down:4:wrap)

  [[ -z "$sel" ]] && return 0
  local cwd session
  cwd=$(echo "$sel" | cut -f5 | sed 's/[[:space:]]*$//')
  session=$(echo "$sel" | cut -f3 | tr -d ' ')
  if [[ ! -d "$cwd" ]]; then
    echo "cs-recent: cwd no longer exists: $cwd" >&2
    return 1
  fi
  cd "$cwd" && claude --resume "$session"
}
# cs-here — fzf picker filtered to sessions whose cwd is under $PWD.
# Useful in a project root: shows only this repo's sessions (including
# worktrees under .worktrees/). Add an arg to filter by an explicit prefix.
cs-here() {
  local prefix="${1:-$PWD}"
  local sel
  sel=$(~/bin/claude-sessions-list | awk -F'\t' -v p="$prefix" '
    BEGIN { plen = length(p) }
    { if (substr($5, 1, plen) == p) print }
  ' | awk -F'\t' -v OFS='\t' '{ printf "%-4s\t%-32s\t%s\t%s\t%s\n", $1, $2, $3, $4, $5 }' | fzf \
    --delimiter=$'\t' \
    --with-nth=1,2,4 \
    --header="claude sessions under ${prefix//$HOME/\~} — Enter resume, Esc cancel" \
    --reverse --no-sort --height=80% \
    --prompt='here> ' \
    --preview='echo "session: {3}"; echo "cwd:     {5}"; echo; echo "{4}"' \
    --preview-window=down:4:wrap)

  [[ -z "$sel" ]] && return 0
  local cwd session
  cwd=$(echo "$sel" | cut -f5 | sed 's/[[:space:]]*$//')
  session=$(echo "$sel" | cut -f3 | tr -d ' ')
  if [[ ! -d "$cwd" ]]; then
    echo "cs-here: cwd no longer exists: $cwd" >&2
    return 1
  fi
  cd "$cwd" && claude --resume "$session"
}

