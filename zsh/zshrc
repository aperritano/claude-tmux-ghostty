# Claude Code — named tab launcher (pinned title; survives auto-titler)
cc() {
  local name="${1:-claude}"
  export PANE_TITLE_LOCK=1
  print -n "\033]0;${name}\007"
  print -n "\033]2;${name}\007"
  shift 2>/dev/null
  claude "$@"
  unset PANE_TITLE_LOCK
}

# Auto-title the tmux pane with git/worktree context on every prompt.
# Flow: OSC 2 → tmux pane_title → tmux window name (via automatic-rename-format)
#       → Ghostty tab strip. Honors PANE_TITLE_LOCK so `cc` names stick.
_update_pane_title() {
  [[ -n "$PANE_TITLE_LOCK" ]] && return
  local toplevel title
  toplevel=$(command git rev-parse --show-toplevel 2>/dev/null)
  if [[ -n "$toplevel" ]]; then
    local branch
    branch=$(command git branch --show-current 2>/dev/null)
    if [[ "$toplevel" == */.worktrees/* ]]; then
      local parent="${toplevel%%/.worktrees/*}"
      local wt="${toplevel##*/.worktrees/}"
      title="${parent:t}:wt/${wt%%/*}"
    else
      title="${toplevel:t}${branch:+:$branch}"
    fi
  else
    title="${PWD:t}"
  fi
  print -n "\033]2;${title}\a"
}
autoload -Uz add-zsh-hook
add-zsh-hook chpwd  _update_pane_title
add-zsh-hook precmd _update_pane_title

