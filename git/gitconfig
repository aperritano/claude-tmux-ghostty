[user]
	name = Anthony Perritano
	email = anthony.j.perritano@gmail.com

[init]
	defaultBranch = main

[core]
	editor = vim
	pager = delta
	autocrlf = input
	excludesFile = ~/.gitignore_global

[pull]
	rebase = true

[push]
	default = current
	autoSetupRemote = true

[fetch]
	prune = true

[merge]
	conflictStyle = zdiff3

[diff]
	algorithm = histogram
	colorMoved = default

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[rebase]
	autoStash = true

[rerere]
	enabled = true

[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
	lg = log --oneline --graph --decorate --all
	last = log -1 HEAD
	unstage = reset HEAD --
	amend = commit --amend --no-edit
