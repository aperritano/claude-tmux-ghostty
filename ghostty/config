# Theme: stock Apple Classic (amber-on-dark) from iTerm2-Color-Schemes, bundled with Ghostty.
# Custom apple-classic-readable / claude-code themes still in ~/.config/ghostty/themes/ if needed.
theme = Apple Classic
# Override Apple Classic's #2c2b2b with a darker, slightly warm near-black.
background = #1a1818

# Font
font-family = JetBrainsMono Nerd Font Mono
font-size = 14
font-thicken = false
# Reduced from 20% — large values cause ghost pixels during TUI scroll in tmux
adjust-cell-height = 10%

# Padding & window
window-padding-x = 16
window-padding-y = 16
window-padding-balance = true
macos-titlebar-style = transparent

# Cursor
cursor-style = bar
cursor-style-blink = false

# Shell integration
shell-integration = detect
# Dropped 'title' — zshrc has _update_pane_title hook emitting OSC 2 directly.
# Letting Ghostty also manage the title caused both to fight on every prompt.
shell-integration-features = cursor,sudo

# Session restore
window-save-state = always

# Scrollback
scrollback-limit = 100000

# Smooth scrolling (reduces jerkiness with tmux)
window-vsync = true

# Clipboard & notifications
copy-on-select = true
desktop-notifications = true

# macOS option key
macos-option-as-alt = true

# Split keybinds (disabled — tmux handles this)
# keybind = cmd+opt+j=new_split:right
# keybind = cmd+opt+i=new_split:down
# keybind = cmd+opt+enter=toggle_split_zoom
# keybind = cmd+opt+equal=equalize_splits

# Vim-style pane navigation (disabled — tmux handles this)
# keybind = ctrl+h=goto_split:left
# keybind = ctrl+j=goto_split:bottom
# keybind = ctrl+k=goto_split:top
# keybind = ctrl+l=goto_split:right

# Prompt jumping — works in plain shell (jumps between zsh prompt marks via
# OSC 133 from shell-integration). Does NOT navigate between Claude turns
# inside the `claude` TUI — Claude Code does not emit OSC 133 around its own
# prompts (4 open issues as of 2026-04). Useful outside Claude, no-op inside.
keybind = cmd+up=jump_to_prompt:-1
keybind = cmd+down=jump_to_prompt:1
