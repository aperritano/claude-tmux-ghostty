# Theme: claude-code (dark) + claude-code-light (light), auto-switching.
# Previous themes: Alien Blood / Green CRT saved in themes/*.bak
# Theme files live at ~/.config/ghostty/themes/
theme = dark:claude-code,light:claude-code-light

# Font
font-family = NotoMono Nerd Font Mono
font-size = 14
font-thicken = false
# Reduced from 20% — large values cause ghost pixels during TUI scroll in tmux
adjust-cell-height = 10%

# Padding & window
window-padding-x = 16
window-padding-y = 16
window-padding-balance = true
macos-titlebar-style = transparent

# Cursor
cursor-style = bar
cursor-style-blink = false

# Shell integration
shell-integration = detect
shell-integration-features = cursor,sudo,title

# Session restore
window-save-state = always

# Scrollback
scrollback-limit = 100000

# Smooth scrolling (reduces jerkiness with tmux)
window-vsync = true

# Clipboard & notifications
copy-on-select = true
desktop-notifications = true

# macOS option key
macos-option-as-alt = true

# Split keybinds (disabled — tmux handles this)
# keybind = cmd+opt+j=new_split:right
# keybind = cmd+opt+i=new_split:down
# keybind = cmd+opt+enter=toggle_split_zoom
# keybind = cmd+opt+equal=equalize_splits

# Vim-style pane navigation (disabled — tmux handles this)
# keybind = ctrl+h=goto_split:left
# keybind = ctrl+j=goto_split:bottom
# keybind = ctrl+k=goto_split:top
# keybind = ctrl+l=goto_split:right

# Prompt jumping
keybind = cmd+up=jump_to_prompt:-1
keybind = cmd+down=jump_to_prompt:1
